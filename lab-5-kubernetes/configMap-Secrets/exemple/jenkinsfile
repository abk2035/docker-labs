pipeline {

    agent any

    environment {

        IMAGE_NAME = "fastapi-app"
        APP_DIR = "lab-5-kubernetes/configMap-Secrets/exemple"

        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Initialisation') {

            steps {

                script {

                    if (isUnix()) {
                        env.OS_TYPE = "LINUX"
                    }
                    else {
                        env.OS_TYPE = "WINDOWS"
                    }

                    echo "OS = ${env.OS_TYPE}"
                }
            }
        }

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/abk2035/docker-labs.git'
            }
        }

        stage('Build Image') {

            steps {

                dir("${APP_DIR}") {

                    script {

                        if (isUnix()) {

                            sh """
                            docker build \
                            -t ${IMAGE_NAME}:${IMAGE_TAG} .
                            """

                        } else {

                            bat """
                            docker build ^
                            -t ${IMAGE_NAME}:${IMAGE_TAG} .
                            """
                        }
                    }
                }
            }
        }

        stage('Run Tests') {

            steps {

                dir("${APP_DIR}") {

                    script {

                        if (isUnix()) {

                            sh """
                            docker run --rm \
                            ${IMAGE_NAME}:${IMAGE_TAG} \
                            pytest tests/
                            """

                        } else {

                            bat """
                            docker run --rm ^
                            ${IMAGE_NAME}:${IMAGE_TAG} ^
                            pytest tests/
                            """
                        }
                    }
                }
            }
        }

        stage('Tag Latest') {

            steps {

                script {

                    if (isUnix()) {

                        sh """
                        docker tag \
                        ${IMAGE_NAME}:${IMAGE_TAG} \
                        ${IMAGE_NAME}:latest
                        """

                    } else {

                        bat """
                        docker tag ^
                        ${IMAGE_NAME}:${IMAGE_TAG} ^
                        ${IMAGE_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Create Kubernetes Secret') {

            steps {

                withCredentials([
                    
                    string(
                        credentialsId: 'postgres_password',
                        variable: 'POSTGRES_PASSWORD'
                    ),
                    string(
                        credentialsId: 'postgres_user',
                        variable: 'POSTGRES_USER'
                    ),

                    string(
                        credentialsId: 'jwt_secret',
                        variable: 'SECRET_KEY'
                    )


                ]) {

                    script {
                        

                        if (isUnix()) {

                            sh '''
                            
                            #pour permettre a jenkins de lancer les commandes kubectl
                            #le hubeconfig est stocké dans un fichier temporaire %USERPROFILE%\\.kube\\config et change à chaque redemarrage de mnikube
                            #on le recupere donc directement sur la machine ou minikube est installé
                            set KUBECONFIG=%USERPROFILE%\\.kube\\config

                            echo ===== WHOAMI =====
                            whoami

                            echo ===== CLUSTER INFO =====
                            kubectl cluster-info

                            echo ===== NODES =====
                            kubectl get nodes

                            kubectl create secret generic fastapi-secret \
                              --from-literal=POSTGRES_USER=$POSTGRES_USER \
                              --from-literal=POSTGRES_PASSWORD=$POSTGRES_PASSWORD \
                              --from-literal=SECRET_KEY=$SECRET_KEY \
                              --dry-run=client -o yaml | kubectl apply -f - --validate=false
                            '''

                        } else {

                            bat '''

                            :: pour permettre a jenkins de lancer les commandes kubectl
                            ::le hubeconfig est stocké dans un fichier temporaire %USERPROFILE%\\.kube\\config et change à chaque redemarrage de mnikube
                            :: on le recupere donc directement sur la machine ou minikube est installé
                            set KUBECONFIG=%USERPROFILE%\\.kube\\config

                            echo ===== CLUSTER INFO =====
                            kubectl cluster-info

                            echo ===== NODES =====
                            kubectl get nodes

                            kubectl create secret generic fastapi-secret ^
                              --from-literal=POSTGRES_USER=%POSTGRES_USER% ^
                              --from-literal=POSTGRES_PASSWORD=%POSTGRES_PASSWORD% ^
                              --from-literal=SECRET_KEY=%SECRET_KEY% ^
                              --dry-run=client -o yaml | kubectl apply -f - --validate=false
                            '''
                        }
                    }
                }
            }
        }

        stage('Load Image Into Minikube') {

                    steps {

                        script {

                            if (isUnix()) {

                                sh """
                                minikube image load ${IMAGE_NAME}:latest
                                """

                            } else {

                                bat """
                                minikube image load ${IMAGE_NAME}:latest
                                """
                            }
                        }
                    }
        }

        stage('Deploy Kubernetes') {

            steps {

                dir("${APP_DIR}") {

                    script {

                        if (isUnix()) {

                            sh '''

                            kubectl apply -f k8s/configmap.yaml

                            kubectl apply -f k8s/postgres-deployment.yaml
                            kubectl apply -f k8s/postgres-service.yaml

                            kubectl apply -f k8s/deployment.yaml
                            kubectl apply -f k8s/service.yaml

                            kubectl rollout restart deployment/postgres

                            kubectl rollout restart deployment/fastapi-app

                            '''
                        }
                        else {

                            bat '''


                            kubectl apply -f k8s/configmap.yaml

                            kubectl apply -f k8s/postgres-deployment.yaml
                            kubectl apply -f k8s/postgres-service.yaml

                            kubectl apply -f k8s/deployment.yaml
                            kubectl apply -f k8s/service.yaml

                            kubectl rollout restart deployment/postgres

                            kubectl rollout restart deployment/fastapi-app

                            '''
                        }
                    }
                }
            }
        }

        stage('Verification') {

            steps {

                script {

                    if (isUnix()) {

                        sh '''
                        kubectl get pods
                        kubectl get svc
                        '''
                    }
                    else {

                        bat '''
                        kubectl get pods
                        kubectl get svc
                        '''
                    }
                }
            }
        }
    }

    post {

        success {

            echo "Déploiement Kubernetes terminé avec succès."
        }

        failure {

            echo "Erreur pendant le pipeline."
        }

        always {

            script {

                if (isUnix()) {

                    sh "docker image prune -f"

                } else {

                    bat "docker image prune -f"
                }
            }
        }
    }
}