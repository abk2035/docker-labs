pipeline {
    agent any

    environment {
        IMAGE_NAME = "fastapi-app"
        APP_DIR = "lab-4"
    }

    stages {
        stage('Initialisation & Détection') {
            steps {
                script {
                    // Détection du système d'exploitation pour adapter les commandes
                    if (isUnix()) {
                        env.OS_TYPE = "LINUX"
                        env.SHELL_CMD = "sh"
                    } else {
                        env.OS_TYPE = "WINDOWS"
                        env.SHELL_CMD = "bat"
                    }
                    echo "Système détecté : ${env.OS_TYPE}"
                }
            }
        }

        stage('Récupération du Code') {
            steps {
                git branch: 'main', url: 'https://github.com/abk2035/docker-labs.git'
            }
        }

        stage('Construction de l\'image Docker') {
            steps {
                dir("${env.APP_DIR}") {
                    script {
                        if (env.OS_TYPE == "LINUX") {
                            sh "docker build -t ${env.IMAGE_NAME}:test-build ."
                        } else {
                            bat "docker build -t ${env.IMAGE_NAME}:test-build ."
                        }
                    }
                }
            }
        }

        stage('Exécution des Tests Unitaires') {
            steps {
                dir("${env.APP_DIR}") {
                    echo "Lancement des tests avec Pytest sur ${env.OS_TYPE}..."
                    script {
                        if (env.OS_TYPE == "LINUX") {
                            sh "docker run --rm ${env.IMAGE_NAME}:test-build pytest test/"
                        } else {
                            bat "docker run --rm ${env.IMAGE_NAME}:test-build pytest test/"
                        }
                    }
                }
            }
        }

        stage('Déploiement') {
            steps {
                dir("${env.APP_DIR}") {
                    script {
                        echo "Préparation du déploiement des services..."
                        if (env.OS_TYPE == "LINUX") {
                            sh "docker tag ${env.IMAGE_NAME}:test-build ${env.IMAGE_NAME}:latest"
                            sh "docker compose down || true"
                            sh "docker compose up -d --build"
                        } else {
                            bat "docker tag ${env.IMAGE_NAME}:test-build ${env.IMAGE_NAME}:latest"
                            bat "docker compose down || ver>nul"
                            bat "docker compose up -d --build"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            echo "Nettoyage des images inutilisées..."
            script {
                if (env.OS_TYPE == "LINUX") {
                    sh "docker image prune -f"
                } else {
                    bat "docker image prune -f"
                }
            }
        }
        success {
            echo "Pipeline terminé avec succès sur ${env.OS_TYPE} !"
        }
        failure {
            echo "Échec du pipeline sur ${env.OS_TYPE}. Vérifiez les logs."
        }
    }
}